# ═══════════════════════════════════════════════════════════════════════
# AI Receptionist SaaS — Environment Variables Reference
# Copy per-app examples for local development:
#   apps/api/.env.example          → apps/api/.env
#   apps/admin-dashboard/.env.example
#   apps/client-dashboard/.env.example
# ═══════════════════════════════════════════════════════════════════════

# ── API (Render / Docker) ──────────────────────────────────────────────
# NODE_ENV=production
# PORT=3001
# PUBLIC_API_URL=https://api.yourdomain.com
# CORS_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com

# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...          # NEVER expose to browsers

# ENCRYPTION_KEY=your-32-char-minimum-secret

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# GOOGLE_CLIENT_EMAIL=sa@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# DEFAULT_VOICE_ID=Elliot
# TRIAL_DAYS=14

# ── Admin Dashboard (Vercel) ───────────────────────────────────────────
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_API_URL=https://api.yourdomain.com

# ── Client Dashboard (Vercel) ──────────────────────────────────────────
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_API_URL=https://api.yourdomain.com
